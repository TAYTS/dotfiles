[user]
  name = "<username>"
  email = "<user_email>" 

[core]
  editor = "vim"

[fetch]
  prune = true
  pruneTags = true
  all = true

[pull]
  rebase = true

[alias]
  lg = "log --graph --pretty=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all"
